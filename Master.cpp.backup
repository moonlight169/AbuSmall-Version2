#include <Arduino.h>
#include <Wire.h>

#define Address 0x04

void setup() {
  Serial.begin(115200);
  Wire.begin(); 
  Serial.println("I2C Master พร้อมทำงาน!");
}

void loop() {
  Wire.beginTransmission(Address); 
  Wire.write("Hello Slave!"); // ส่งข้อความ
  Wire.endTransmission();
  delay(1000);

  Serial.print("ข้อมูลที่ Slave ตอบกลับมา: ");
  
  // ร้องขอข้อมูลจำนวน 2 ไบต์ จาก Slave
  Wire.requestFrom(Address, 2); 
  
  while (Wire.available()) {
    char c = Wire.read();
    Serial.print(c);
  }
  Serial.println();
  Serial.println("-----------------------");

  delay(2000);
}